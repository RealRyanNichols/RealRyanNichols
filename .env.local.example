# Supabase Configuration
# Get these from your Supabase project: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public site URL for Stripe redirects
NEXT_PUBLIC_SITE_URL=https://www.repwatchr.com

# Stripe profile membership subscriptions
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PROFILE_PRICE_ID=price_your_profile_membership_price
# Optional fallback if you need to expose the selected price ID in client copy later
NEXT_PUBLIC_STRIPE_PROFILE_PRICE_ID=price_your_profile_membership_price

# Google Analytics (optional)
# Get from https://analytics.google.com/ - create a GA4 property
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
