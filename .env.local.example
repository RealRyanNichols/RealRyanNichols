# Supabase Configuration
# Get these from your Supabase project: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public site URL for Stripe redirects
NEXT_PUBLIC_SITE_URL=https://www.repwatchr.com

# GideonAI chat bridge
# Server-side proxy target for the GideonAI Supabase Edge Function.
# Example: https://<project-ref>.functions.supabase.co/gideon-chat
GIDEON_CHAT_URL=
# Optional bearer token if the Gideon Edge Function requires one.
GIDEON_CHAT_BEARER=
# Optional public URL only if you intentionally want browser-side widgets to call Gideon directly.
NEXT_PUBLIC_GIDEON_CHAT_URL=

# Quo / OpenPhone call-text automation
# Configure a Quo webhook for https://www.repwatchr.com/api/quo/webhook and select message.received.
QUO_WEBHOOK_SIGNING_SECRET=base64_signing_secret_from_quo
QUO_API_KEY=quo_or_openphone_api_key
QUO_PHONE_NUMBER_ID=PN_your_quo_number_id
QUO_FROM_NUMBER=+19039611776
# Keep false until Gideon is tested for short public SMS answers.
QUO_USE_GIDEON_AUTO_REPLY=false
# Optional override if Quo changes the OpenPhone-compatible messages endpoint.
QUO_MESSAGES_URL=https://api.openphone.com/v1/messages

# Stripe profile membership subscriptions
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PROFILE_PRICE_ID=price_your_profile_membership_price
# Optional fallback if you need to expose the selected price ID in client copy later
NEXT_PUBLIC_STRIPE_PROFILE_PRICE_ID=price_your_profile_membership_price

# Google Analytics (optional)
# Get from https://analytics.google.com/ - create a GA4 property
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
